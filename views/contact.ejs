<%- include('partials/head') %>
<%- include('partials/header') %>


<section class="relative min-h-[60vh] flex items-end overflow-hidden pt-24 pb-20">
  <div class="absolute inset-0">
    <img src="assets/port-sunset.jpg" alt="" class="photo-crisp w-full h-full object-cover photo-crisp hero-media" fetchpriority="high" decoding="async"/>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-deep/85 via-navy-deep/55 to-navy-deep/30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-deep via-navy-deep/20 to-transparent"></div>
  </div>
  <div class="container mx-auto px-4 lg:px-8 relative z-10">
    <div class="reveal inline-flex items-center gap-3 px-4 py-2 rounded-full border border-gold/40 bg-navy-deep/40 backdrop-blur">
      <span class="h-1.5 w-1.5 rounded-full bg-gold animate-pulse"></span>
      <span class="text-xs font-heading uppercase tracking-[0.3em] text-gold-light">Contact Us</span>
    </div>
    <h1 class="reveal mt-6 font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.05] text-ivory max-w-4xl">Let's <span class="text-gold-gradient italic" style="padding-right: 0.15em;">set sail</span> together.</h1>
    <p class="reveal mt-6 text-lg text-ivory/80 max-w-2xl leading-relaxed">Whether it's STS, pilotage, bunkering or full marine advisory &mdash; our team is on standby.</p>
  </div>
</section>

<section class="py-24">
  <div class="container mx-auto px-4 lg:px-8 grid lg:grid-cols-[1fr,1.2fr] gap-12">
    <div class="reveal">
      <h2 class="font-heading text-3xl md:text-4xl">Get in touch.</h2>
      <p class="mt-3 text-slate-600">Reach out for marine operations, advisory or any commercial enquiry.</p>
      <ul class="mt-8 space-y-6">
        <li class="flex gap-4"><div class="h-12 w-12 rounded-xl bg-gold-gradient flex items-center justify-center shrink-0 shadow-gold text-navy-deep"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg></div><div><p class="font-heading font-semibold">Office</p><p class="text-slate-600 text-sm leading-relaxed mt-1">3J-13-1 Straits Quay, Jalan Seri Tanjung Pinang, Tanjung Tokong 10470 Pulau Pinang.</p></div></li>
        <li class="flex gap-4"><div class="h-12 w-12 rounded-xl bg-gold-gradient flex items-center justify-center shrink-0 shadow-gold text-navy-deep"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div><div><p class="font-heading font-semibold">Telephone</p><a href="tel:+60165063003" class="block text-slate-600 text-sm hover:text-gold-dark mt-1">+60165063003</a></div></li>
        <li class="flex gap-4"><div class="h-12 w-12 rounded-xl bg-gold-gradient flex items-center justify-center shrink-0 shadow-gold text-navy-deep"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div><div><p class="font-heading font-semibold">Email</p><a href="mailto:info@ddsmarine.com" class="text-slate-600 text-sm hover:text-gold-dark mt-1 block">info@ddsmarine.com</a></div></li>
        <li class="flex gap-4"><div class="h-12 w-12 rounded-xl bg-gold-gradient flex items-center justify-center shrink-0 shadow-gold text-navy-deep"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg></div><div><p class="font-heading font-semibold">Website</p><p class="text-slate-600 text-sm mt-1">www.ddsmarine.com</p></div></li>
        <li class="flex gap-4"><div class="h-12 w-12 rounded-xl bg-gold-gradient flex items-center justify-center shrink-0 shadow-gold text-navy-deep"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg></div><div><p class="font-heading font-semibold">LinkedIn</p><a href="https://www.linkedin.com/company/dds-marine-energy" target="_blank" rel="noopener noreferrer" class="text-slate-600 text-sm hover:text-gold-dark mt-1 block font-semibold">dds-marine-energy</a></div></li>
      </ul>
      <div class="mt-10 aspect-[4/3] rounded-2xl overflow-hidden border border-slate-200 shadow-elegant">
        <iframe title="DDS Marine office location" src="https://www.google.com/maps?q=Straits+Quay+Marina+Tanjung+Tokong+Penang&output=embed" class="w-full h-full" loading="lazy" decoding="async"></iframe>
      </div>
    </div>

    <div class="reveal" x-data="{ sent: false, sending: false }">
      <form action="/send-mail" method="POST"
            @submit="sending = true"
            class="p-8 lg:p-10 rounded-3xl bg-white border border-slate-200 shadow-elegant space-y-5">
        <input type="hidden" name="_next" value="thankyou.html" />
        <h3 class="font-heading text-2xl font-semibold">Send us a message</h3>
        <div class="grid sm:grid-cols-2 gap-5">
          <div><label class="text-sm font-medium block mb-2">Full Name <span class="text-red-500">*</span></label><input type="text" name="name" required class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition"/></div>
          <div><label class="text-sm font-medium block mb-2">Company</label><input type="text" name="company" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition"/></div>
          <div><label class="text-sm font-medium block mb-2">Email <span class="text-red-500">*</span></label><input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition"/></div>
          <div><label class="text-sm font-medium block mb-2">Phone</label><input type="tel" name="phone" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition"/></div>
        </div>
        <div><label class="text-sm font-medium block mb-2">Subject <span class="text-red-500">*</span></label><input type="text" name="subject" required class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition"/></div>
        <div><label class="text-sm font-medium block mb-2">Message</label><textarea name="message" required rows="5" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition resize-none"></textarea></div>
        <button type="submit" :disabled="sending" class="w-full inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full bg-gold-gradient text-navy-deep font-semibold shadow-gold hover:scale-[1.02] transition-transform disabled:opacity-70">
          <span x-text="sending ? 'Sending...' : 'Send Message'"></span><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
        </button>
        <p class="text-xs text-slate-500 text-center">We typically respond within one business day.</p>
      </form>
    </div>
  </div>
</section>

