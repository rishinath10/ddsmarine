<body x-data="{ mobileOpen: false }">

  <div id="preloader" aria-hidden="true">
    <div class="loader-mark">
      <img src="assets/dds-logo-transparent.png" alt="DDS Marine" class="loader-logo" />
      <div class="loader-brand mt-4">DDS Marine</div>
    </div>
  </div>



  <header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-xl border-b border-slate-200/80 shadow-sm">
    <div class="container mx-auto px-4 lg:px-8 flex items-center justify-between py-3">
      <a href="/" class="flex items-center gap-3">
        <img src="assets/dds-logo-transparent.png" alt="DDS Marine" class="h-14 w-auto" />
        <span class="font-bebas text-navy text-lg sm:text-2xl tracking-wider leading-none mt-1">DDS MARINE ENERGY
          SERVICES</span>
      </a>
      <nav class="hidden lg:flex items-center gap-1"><a href="/"
          class="relative px-4 py-2 text-sm font-medium tracking-wide transition-colors text-navy hover:text-gold-dark">Home<span
            class="absolute left-3 right-3 -bottom-0.5 h-[2px] bg-gold-gradient rounded-full"></span></a><a
          href="/about"
          class="relative px-4 py-2 text-sm font-medium tracking-wide transition-colors text-navy hover:text-gold-dark">About</a><a
          href="/services"
          class="relative px-4 py-2 text-sm font-medium tracking-wide transition-colors text-navy hover:text-gold-dark">Services</a><a
          href="/partners"
          class="relative px-4 py-2 text-sm font-medium tracking-wide transition-colors text-navy hover:text-gold-dark">Partners</a><a
          href="/projects"
          class="relative px-4 py-2 text-sm font-medium tracking-wide transition-colors text-navy hover:text-gold-dark">Projects</a><a
          href="/team"
          class="relative px-4 py-2 text-sm font-medium tracking-wide transition-colors text-navy hover:text-gold-dark">Team</a><a
          href="/contact"
          class="relative px-4 py-2 text-sm font-medium tracking-wide transition-colors text-navy hover:text-gold-dark">Contact</a>
      </nav>
      <a href="/contact"
        class="hidden lg:inline-flex items-center px-5 py-2.5 rounded-full text-sm font-semibold bg-gold-gradient text-navy-deep shadow-gold hover:scale-105 transition-transform">Get
        in Touch</a>
      <button @click="mobileOpen = !mobileOpen" class="lg:hidden text-navy p-2" aria-label="Toggle menu">
        <span x-show="!mobileOpen"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
            <line x1="4" x2="20" y1="12" y2="12" />
            <line x1="4" x2="20" y1="6" y2="6" />
            <line x1="4" x2="20" y1="18" y2="18" />
          </svg></span>
        <span x-show="mobileOpen" x-cloak><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
            <path d="M18 6 6 18" />
            <path d="m6 6 12 12" />
          </svg></span>
      </button>
    </div>
    <div x-show="mobileOpen" x-cloak x-transition class="lg:hidden bg-white border-t border-slate-200/80">
      <nav class="flex flex-col p-4 gap-1"><a href="/"
          class="block px-4 py-3 rounded-lg text-base font-medium text-navy bg-gold/10">Home</a><a href="/about"
          class="block px-4 py-3 rounded-lg text-base font-medium text-navy hover:bg-navy/5">About</a><a
          href="/services"
          class="block px-4 py-3 rounded-lg text-base font-medium text-navy hover:bg-navy/5">Services</a><a
          href="/partners"
          class="block px-4 py-3 rounded-lg text-base font-medium text-navy hover:bg-navy/5">Partners</a><a
          href="/projects"
          class="block px-4 py-3 rounded-lg text-base font-medium text-navy hover:bg-navy/5">Projects</a><a
          href="/team" class="block px-4 py-3 rounded-lg text-base font-medium text-navy hover:bg-navy/5">Team</a><a
          href="/contact"
          class="block px-4 py-3 rounded-lg text-base font-medium text-navy hover:bg-navy/5">Contact</a>
        <a href="/contact"
          class="mt-3 inline-flex justify-center items-center px-5 py-3 rounded-full text-sm font-semibold bg-gold-gradient text-navy-deep">Get
          in Touch</a>
      </nav>
    </div>
  </header>
  <div class="h-20"></div>